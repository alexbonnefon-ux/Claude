# ─────────────────────────────────────────────────────────────────────────────
# Job Search Agent – environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── SerpAPI key (REQUIRED for job searching) ─────────────────────────────────
# Replaces LinkedIn and WTTJ scrapers with reliable Google Jobs search.
# Sign up free at https://serpapi.com  (100 searches / month on free plan)
SERPAPI_KEY=your_serpapi_key_here

# ── Scraping behaviour ────────────────────────────────────────────────────────
# Delay in seconds between HTTP requests
REQUEST_DELAY=2.0

# ── Gmail SMTP (optional – only needed if you re-enable email sending) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
