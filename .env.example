# ─────────────────────────────────────────────────────────────────────────────
# Job Search Agent – environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gmail SMTP (required for sending email digests) ──────────────────────────
# Use a Gmail App Password (NOT your main Gmail password).
# How to generate:  Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # 16-char App Password (spaces optional)

# ── LinkedIn credentials (optional – improves scraping reliability) ───────────
# Without these the LinkedIn scraper runs in unauthenticated mode,
# which may be blocked more aggressively by LinkedIn.
LINKEDIN_EMAIL=your.linkedin@email.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── Scraping behaviour ────────────────────────────────────────────────────────
# Delay in seconds between HTTP requests (be polite to servers)
REQUEST_DELAY=2.0
