# ============================================================
# Job Scraper – Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================

# Anthropic API (for Claude job scoring)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Gmail credentials (for sending the daily digest)
# Use an App Password, NOT your main Gmail password.
# Enable 2FA, then generate an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Recipient email address (who gets the digest)
RECIPIENT_EMAIL=alexbonnefon@gmail.com

# France Travail API credentials
# Register at: https://francetravail.io/
# Create an application and request access to the "Offres d'emploi" API
FRANCE_TRAVAIL_CLIENT_ID=your_client_id
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret

# (Optional) SendGrid API key – fallback email sender
# SENDGRID_API_KEY=SG.xxxx

# SQLite database path (relative to project root)
DB_PATH=jobs.db
