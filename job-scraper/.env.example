# ============================================================
# HR Job Radar – Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================

# Anthropic API (for Claude job scoring)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_key_here

# Recipient email (informational only, used in config)
RECIPIENT_EMAIL=alexbonnefon@gmail.com

# France Travail API credentials
# Register at: https://francetravail.io/
# Create an application and request access to the "Offres d'emploi" API
FRANCE_TRAVAIL_CLIENT_ID=your_id_here
FRANCE_TRAVAIL_CLIENT_SECRET=your_secret_here

# SQLite database path (relative to project root)
DB_PATH=jobs.db
